# Copy this file to `.env` and fill in real values for your machine.
# Never commit the real `.env` file - it is listed in .gitignore.

# --- Paths ---------------------------------------------------------------
# Source data (extract step reads from here)
SOURCE_DATA_PATH=data/source/raw_sensor_data.csv

# Target database (load step writes here). SQLite is used for portability;
# swap for a Postgres/MySQL connection string in production.
TARGET_DB_PATH=data/processed/warehouse.db
TARGET_TABLE=sensor_readings

# Great Expectations suite used as the quality gate
GE_SUITE_PATH=great_expectations/expectations/sensor_data_suite.json

# --- Logging ---------------------------------------------------------------
LOG_FILE=pipeline.log
LOG_LEVEL=INFO

# --- Quality thresholds (referenced by the suite / transform step) --------
MIN_TEMPERATURE_C=-40
MAX_TEMPERATURE_C=100
MIN_PRESSURE_KPA=0
MAX_PRESSURE_KPA=300
MIN_HUMIDITY_PCT=0
MAX_HUMIDITY_PCT=100

# --- Pipeline behaviour -----------------------------------------------------
# If true, the pipeline aborts (exit code 1) on any failed expectation.
# If false, it logs a warning and continues (not recommended for production).
HALT_ON_VALIDATION_FAILURE=true
